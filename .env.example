cp .env.example .env
# open frontend/.env and set:
# VITE_PB_URL=http://localhost:8090
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_...
# VITE_ADMIN_WHATSAPP=234803...# ══════════════════════════════════════════════════════
#  Nura Bahar Nigeria — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file to version control.
# ══════════════════════════════════════════════════════

# ── PocketBase ────────────────────────────────────────
# URL your frontend uses to reach PocketBase
VITE_PB_URL=http://localhost:8090

# ── Paystack ──────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developer
# Use pk_test_... for testing, pk_live_... for production
VITE_PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PAYSTACK_PUBLIC_KEY

# ── WhatsApp Admin ────────────────────────────────────
# Your WhatsApp number in international format (no +, no spaces)
# Example: +234 803 123 4567 → 2348031234567
VITE_ADMIN_WHATSAPP=2348000000000

# ── Site Config ───────────────────────────────────────
VITE_SITE_NAME=Nura Bahar Nigeria
VITE_SITE_URL=https://nurabahar.ng
